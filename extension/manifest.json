{
  "manifest_version": 3,
  "name": "N网下载器-NYPD",
  "version": "1.0.5.1",
  "key": "",
  "description": "《N网下载器-NYPD》的附属插件，安装后会自动识别n网下载请求并启动下载器。",
  "permissions": ["downloads", "nativeMessaging", "storage"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_title": "N网下载器-NYPD",
    "default_popup": "popup.html"
  }
}
