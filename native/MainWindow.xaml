<Window x:Class="NexusModsDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="N网下载器-NYPD"
        Icon="ico.png"
        Height="720"
        Width="1180"
        MinHeight="560"
        MinWidth="980"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TextElement.FontSize="13"
        FontFamily="Microsoft YaHei">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Blue" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.Blue.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Accent/MaterialDesignColor.Blue.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MaterialDesignTextBlock}">
                <Setter Property="FontFamily" Value="Microsoft YaHei" />
            </Style>
            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="FontFamily" Value="Microsoft YaHei" />
            </Style>
            <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource MaterialDesignCheckBox}">
                <Setter Property="FontFamily" Value="Microsoft YaHei" />
            </Style>
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="FontFamily" Value="Microsoft YaHei" />
                <Setter Property="MinHeight" Value="32" />
            </Style>

            <Style x:Key="WindowBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="NavButtonStyle" TargetType="RadioButton">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border" Width="56" Height="56" Background="Transparent">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#22FFFFFF" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHueDarkBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
                <Setter Property="Margin" Value="0,0,0,16" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="CellTextStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="Margin" Value="8,0" />
            </Style>

            <Style x:Key="PathTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="ToolTip" Value="{Binding MissingTip}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="TextDecorations" Value="Underline" />
                    </Trigger>
                    <DataTrigger Binding="{Binding DestinationExists}" Value="False">
                        <Setter Property="Foreground" Value="#888888" />
                        <Setter Property="TextDecorations" Value="Strikethrough" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="MissingRowStyle" TargetType="DataGridRow">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DestinationExists}" Value="False">
                        <Setter Property="Foreground" Value="#888888" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FlatProgressBarStyle" TargetType="ProgressBar">
                <Setter Property="Height" Value="5" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid ClipToBounds="True">
                                <Border x:Name="PART_Track" Height="{TemplateBinding Height}" Background="#D9E7F7" CornerRadius="3" />
                                <Border x:Name="PART_Indicator" Height="{TemplateBinding Height}" Background="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Left" CornerRadius="3" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog">
        <Border Style="{StaticResource WindowBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Background="{DynamicResource PrimaryHueMidBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="NYPD">
                        <TextBlock Text="NY" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" />
                        <TextBlock Text="PD" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,-3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <RadioButton Style="{StaticResource NavButtonStyle}" GroupName="Navigation" IsChecked="True" Tag="Downloads" Checked="Navigation_Checked" ToolTip="下载">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Download" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="下载" FontSize="10" HorizontalAlignment="Center" Foreground="White" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButtonStyle}" GroupName="Navigation" Tag="History" Checked="Navigation_Checked" ToolTip="历史记录">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="History" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="历史" FontSize="10" HorizontalAlignment="Center" Foreground="White" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="LogsNavButton" Style="{StaticResource NavButtonStyle}" GroupName="Navigation" Tag="Logs" Checked="Navigation_Checked" ToolTip="日志">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Console" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="日志" FontSize="10" HorizontalAlignment="Center" Foreground="White" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButtonStyle}" GroupName="Navigation" Tag="Settings" Checked="Navigation_Checked" ToolTip="设置">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="设置" FontSize="10" HorizontalAlignment="Center" Foreground="White" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButtonStyle}" GroupName="Navigation" Tag="About" Checked="Navigation_Checked" ToolTip="关于">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Information" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="关于" FontSize="10" HorizontalAlignment="Center" Foreground="White" />
                            </StackPanel>
                        </RadioButton>
                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="56" Height="56" Foreground="White" Click="ThemeButton_Click" ToolTip="主题色">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Palette" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="主题" FontSize="10" HorizontalAlignment="Center" Foreground="White" />
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="园长蓝" Tag="#3898fc" Click="ThemeMenuItem_Click" />
                                    <MenuItem Header="天空蓝" Tag="#4fc3f7" Click="ThemeMenuItem_Click" />
                                    <MenuItem Header="自然青" Tag="#009688" Click="ThemeMenuItem_Click" />
                                    <MenuItem Header="安安绿" Tag="#18a96e" Click="ThemeMenuItem_Click" />
                                    <MenuItem Header="姨妈红" Tag="#f50057" Click="ThemeMenuItem_Click" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid Height="42" VerticalAlignment="Top" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <TextBlock Text="N网下载器-NYPD" VerticalAlignment="Center" Margin="18,0,0,0" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                            <Button Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36" Padding="6" Click="MinimizeButton_Click" ToolTip="最小化">
                                <materialDesign:PackIcon Kind="WindowMinimize" Width="20" Height="20" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36" Padding="6" Click="MaximizeButton_Click" ToolTip="最大化">
                                <materialDesign:PackIcon x:Name="MaximizeIcon" Kind="Fullscreen" Width="20" Height="20" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36" Padding="6" Click="CloseButton_Click" ToolTip="关闭">
                                <materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="22,56,22,22">
                        <Grid x:Name="DownloadsPage">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="下载管理" Style="{StaticResource PageTitleStyle}" />

                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Margin="6,0,0,0" Click="InstallBrowserExtension_Click" ToolTip="释放并安装浏览器插件">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Puzzle" Width="18" Height="18" Margin="0,0,6,0" />
                                                <TextBlock Text="安装浏览器插件" />
                                            </StackPanel>
                                        </Button>
                                        <Button Margin="6,0,0,0" Click="OpenDownloadFolder_Click" ToolTip="打开默认下载目录">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18" Margin="0,0,6,0" />
                                                <TextBlock Text="目录" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BulkPauseButton" Margin="6,0,0,0" Click="ToggleAllPause_Click" ToolTip="暂停或继续所有下载">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon x:Name="BulkPauseIcon" Kind="Pause" Width="18" Height="18" Margin="0,0,6,0" />
                                                <TextBlock x:Name="BulkPauseText" Text="全部暂停" />
                                            </StackPanel>
                                        </Button>
                                        <Button Margin="6,0,0,0" Click="CancelAll_Click" ToolTip="取消所有未完成下载">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Margin="0,0,6,0" />
                                                <TextBlock Text="全部取消" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="MultiSelectButton" Margin="6,0,0,0" Click="ToggleMultiSelect_Click" ToolTip="多选下载记录">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CheckboxMultipleMarkedOutline" Width="18" Height="18" Margin="0,0,6,0" />
                                                <TextBlock x:Name="MultiSelectText" Text="多选模式" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="DeleteSelectedButton" Margin="6,0,0,0" Click="DeleteSelected_Click" Visibility="Collapsed" ToolTip="删除选中的下载记录">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Margin="0,0,6,0" />
                                                <TextBlock Text="删除选中" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <DockPanel Margin="0,0,12,0">
                                        <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconButton}" Width="40" Height="40" Padding="8" Margin="8,0,0,0" Click="ManualDownload_Click" ToolTip="下载此链接">
                                            <materialDesign:PackIcon Kind="Download" Width="20" Height="20" />
                                        </Button>
                                        <TextBox x:Name="ManualUrlTextBox" KeyDown="ManualUrlTextBox_KeyDown" materialDesign:HintAssist.Hint="粘贴 Nexus Mods 下载链接，按回车开始下载" />
                                    </DockPanel>
                                </DockPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                                <DataGrid x:Name="DownloadsGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeColumns="True"
                                          IsReadOnly="True"
                                          RowHeight="52"
                                          ColumnHeaderHeight="40"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          SelectionMode="Single"
                                          RowHeaderWidth="0"
                                          RowStyle="{StaticResource MissingRowStyle}"
                                          PreviewMouseRightButtonDown="DownloadsGrid_PreviewMouseRightButtonDown">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}">
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="8,0" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="打开文件目录" Click="OpenSelectedLocation_Click" />
                                            <Separator />
                                            <MenuItem Header="删除下载记录" Click="DeleteRecord_Click" />
                                            <MenuItem Header="删除文件" Click="DeleteFile_Click" />
                                            <Separator />
                                            <MenuItem Header="复制下载链接" Click="CopyDownloadUrl_Click" />
                                            <MenuItem Header="复制文件路径" Click="CopyFilePath_Click" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn x:Name="MultiSelectColumn" Header="" Width="42" Visibility="Collapsed">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="文件" Binding="{Binding Name}" Width="2*" MinWidth="150" ElementStyle="{StaticResource CellTextStyle}" />
                                        <DataGridTemplateColumn Header="状态" Width="86" MinWidth="76">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StatusDisplay}" ToolTip="{Binding Status}" MouseLeftButtonUp="StatusText_Click">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
                                                                <Setter Property="Cursor" Value="Hand" />
                                                                <Setter Property="Foreground" Value="#555555" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="Foreground" Value="#16803C" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                                        <Setter Property="Foreground" Value="#D32F2F" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="TextDecorations" Value="Underline" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="进度" Width="250" MinWidth="210">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="8,3">
                                                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Style="{StaticResource FlatProgressBarStyle}" />
                                                        <TextBlock Text="{Binding Progress}" Margin="0,3,0,0" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="速度" Binding="{Binding Speed}" Width="124" MinWidth="110" ElementStyle="{StaticResource CellTextStyle}" />
                                        <DataGridTemplateColumn Header="保存位置" Width="1.3*" MinWidth="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Destination}" Style="{StaticResource PathTextStyle}" MouseLeftButtonUp="OpenDownloadPath_Click" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="操作" Width="116" MinWidth="108">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Padding="5" Margin="0,0,4,0" Click="ToggleRowPause_Click" ToolTip="{Binding PauseText}" IsEnabled="{Binding CanPauseResume}">
                                                            <materialDesign:PackIcon Kind="{Binding PauseIcon}" Width="18" Height="18" />
                                                        </Button>
                                                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Padding="5" Margin="0,0,4,0" Click="CancelRow_Click" ToolTip="停止" IsEnabled="{Binding CanCancel}">
                                                            <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                                                        </Button>
                                                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Padding="5" Click="OpenRowLocation_Click" ToolTip="打开文件位置">
                                                            <materialDesign:PackIcon Kind="FolderSearch" Width="18" Height="18" />
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <Grid x:Name="HistoryPage" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="历史记录" Style="{StaticResource PageTitleStyle}" />
                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                                <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserResizeColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" RowHeaderWidth="0" RowStyle="{StaticResource MissingRowStyle}" PreviewMouseRightButtonDown="HistoryGrid_PreviewMouseRightButtonDown">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="打开文件目录" Click="OpenHistoryLocation_Click" />
                                            <MenuItem Header="复制文件路径" Click="CopyHistoryPath_Click" />
                                            <Separator />
                                            <MenuItem Header="删除历史记录" Click="DeleteHistoryRecord_Click" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="150" />
                                        <DataGridTextColumn Header="文件" Binding="{Binding Name}" Width="260" />
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" />
                                        <DataGridTemplateColumn Header="保存位置" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Destination}" Style="{StaticResource PathTextStyle}" MouseLeftButtonUp="OpenHistoryPath_Click" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <Grid x:Name="LogsPage" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="操作日志" Style="{StaticResource PageTitleStyle}" />
                                <Button DockPanel.Dock="Right" Click="ClearLog_Click" HorizontalAlignment="Right" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteSweep" Width="18" Height="18" Margin="0,0,6,0" />
                                        <TextBlock Text="清理日志" />
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                            <Border Grid.Row="1" CornerRadius="8" Background="#111827" Padding="14">
                                <RichTextBox x:Name="LogTextBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" FontFamily="Cascadia Mono" FontSize="13" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                            </Border>
                        </Grid>

                        <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}" />
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="下载目录" VerticalAlignment="Center" />
                                        <TextBox x:Name="DefaultDirectoryTextBox" Grid.Column="1" Margin="0,0,8,12" />
                                        <Button Grid.Column="2" Margin="0,0,0,12" Click="BrowseDefaultDirectory_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18" Margin="0,0,6,0" />
                                                <TextBlock Text="选择" />
                                            </StackPanel>
                                        </Button>

                                        <CheckBox x:Name="AskBeforeCheckBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12" Content="每次下载前显示确认窗口" />

                                        <TextBlock Grid.Row="2" Text="代理下载" VerticalAlignment="Center" />
                                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                            <CheckBox x:Name="UseProxyCheckBox" Content="使用代理" VerticalAlignment="Center" Margin="0,0,16,0" />
                                            <TextBox x:Name="ProxyHostTextBox" Width="180" VerticalAlignment="Center" />
                                            <TextBlock Text=":" VerticalAlignment="Center" Margin="8,0" />
                                            <TextBox x:Name="ProxyPortTextBox" Width="90" VerticalAlignment="Center" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="3" Text="主页 URL" VerticalAlignment="Center" />
                                        <TextBox x:Name="HomepageTextBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,18" />

                                        <TextBlock Grid.Row="4" Text="下载分片数" VerticalAlignment="Center" />
                                        <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,18">
                                            <TextBox x:Name="SegmentCountTextBox" Width="90" VerticalAlignment="Center" />
                                            <TextBlock Text="1-128，默认 64" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="5" Text="浏览器插件" VerticalAlignment="Center" />
                                        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,18">
                                            <Button Click="InstallBrowserExtension_Click" ToolTip="释放插件文件并复制安装目录">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Puzzle" Width="18" Height="18" Margin="0,0,6,0" />
